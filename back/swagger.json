{
  "openapi": "3.0.3",
  "info": {
    "title": "Aula 2 API",
    "version": "1.0.0",
    "description": "API de upload de documentos PDF/Texto e busca semântica via embeddings."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/api/data": {
      "get": {
        "summary": "Health check / sample data",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/upload": {
      "post": {
        "summary": "Upload de arquivo",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                },
                "required": ["file"]
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Upload successful"},
          "400": {"description": "Validation error"}
        }
      }
    },
    "/ask": {
      "post": {
        "summary": "Buscar em documento específico",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "question": {"type": "string"},
                  "doc_id": {"type": "integer"}
                },
                "required": ["question", "doc_id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Matches",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "matches": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "filename": {"type": "string"},
                          "content": {"type": "string"},
                          "distance": {"type": "number"}
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {"description": "Validation error"}
        }
      }
    },
    "/ask_all": {
      "post": {
        "summary": "Buscar nos 3 documentos mais próximos",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "question": {"type": "string"}
                },
                "required": ["question"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Matches",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "matches": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "filename": {"type": "string"},
                          "content": {"type": "string"},
                          "distance": {"type": "number"}
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {"description": "Validation error"}
        }
      }
    },
    "/documents": {
      "get": {
        "summary": "Listar documentos disponíveis",
        "responses": {
          "200": {
            "description": "Document list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "documents": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {"type": "integer"},
                          "filename": {"type": "string"}
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
